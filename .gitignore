# Byte-compiled
__pycache__/
*.py[cod]

# Local secrets — never commit your API key
.env

# Generated state + outputs live on the 'feed' branch, never on master.
# These are only local test artifacts here, so keep the code branch clean.
/data/
/docs/

# Local dev server artifacts
gohup-audit.log
nohup.out

# CLAUDE.md is globally ignored on this machine; keep it tracked in THIS repo.
!CLAUDE.md

# React is vendored for the deployed Hub; globally-ignored "vendor" must stay tracked here.
!web/vendor/
!web/vendor/*
